# https://fal.ai/dashboard/keys
FAL_KEY=

# Workflow text→image (Flux Schnell-compatible). Defaults to fal-ai/flux/schnell (~$0.003/MP on fal; verify on pricing page).
# FAL_TEXT_TO_IMAGE_MODEL=fal-ai/flux/schnell
# Draft savings: JPEG + low queue priority (same billed MP; waits behind normal priority when busy).
# FAL_FLUX_OUTPUT_FORMAT=jpeg
# FAL_QUEUE_LOW_PRIORITY=1
# Throughput knobs (see flux/schnell model docs): none | regular | high — default regular.
# FAL_FLUX_ACCELERATION=regular

# Optional: natural-language workflow layouts via POST /api/workflow/agent
# OPENAI_API_KEY=
# OPENAI_WORKFLOW_MODEL=gpt-5.4-mini

# Optional: require header `x-native-gen-secret: <value>` on every request when set
NATIVE_GEN_GATE_SECRET=

# --- OAuth (optional): YouTube via Google + Facebook/Instagram via Meta ---
# Random string, 32+ characters, used to encrypt tokens in the session cookie
NATIVE_GEN_OAUTH_SECRET=

# Google Cloud OAuth 2.0 (enable YouTube Data API v3). Authorized redirect: /api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta developer app (Facebook Login). Redirect: /api/oauth/meta/callback
# Requires permissions for Page photo + IG feed image publish (reconnect Social accounts after changing scopes).
META_APP_ID=
META_APP_SECRET=

# Production: public site URL so OAuth redirect_uri matches (e.g. https://yourdomain.com)
# NEXT_PUBLIC_APP_URL=

# Optional: store encrypted OAuth blobs in a JSON file (self-hosted). Cookie holds only a session id.
# NATIVE_GEN_OAUTH_PERSIST_PATH=./var/oauth-sessions.json

# Optional: cap YouTube demo uploads (bytes). Default ~32 MB if unset.
# NATIVE_GEN_YOUTUBE_MAX_BYTES=
